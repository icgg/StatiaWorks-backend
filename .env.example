# --- Environment toggle -------------------------------------------------
# THE switch between database + frontend setups:
#   development → local Postgres (DATABASE_URL / PG*), dev CORS origins
#   production  → Supabase (SUPABASE_DB_URL), *_PROD frontend hostnames,
#                 and secure cookies
NODE_ENV=development

# --- Development database (local Postgres) ------------------------------
# Point this at the Postgres DB you already created from schema.txt.
# Either a full connection string:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/statiaworks
# ...or the discrete PG* vars (used only if DATABASE_URL is unset):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=statiaworks

# --- Production database (Supabase) -------------------------------------
# Used ONLY when NODE_ENV=production. We use Supabase purely as a hosted
# Postgres via Knex — NOT its auth. Grab the connection string from
# Supabase → Project Settings → Database → Connection string.
# Use the "Session pooler" string (host ...pooler.supabase.com, port 5432) for
# a long-running Node server, and substitute your DB password for [YOUR-PASSWORD].
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Supabase project URL + service-role key. Used by the file-storage layer in
# production (NODE_ENV=production) to read/write the `uploads` bucket — NOT for
# auth. The service-role key is server-only; never expose it to the browser.
# (SUPABASE_ANON_KEY is currently unused.) Find both under Supabase → Project
# Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Server -------------------------------------------------------------
PORT=3000

# --- Frontend origins (CORS) --------------------------------------------
# Comma-separated allowed browser origins. Dev = the Vite dev servers; used
# when NODE_ENV=development.
APP_ORIGINS=http://localhost:5173,http://localhost:5174
# Production frontend hostname(s) — the deployed app (+ admin) URLs. Used when
# NODE_ENV=production.
APP_ORIGINS_PROD=https://statiaworks.com,https://admin.statiaworks.com

# Base URL of the public app — used to build links in emails (verify, reset).
APP_URL=http://localhost:5173
# Production public app URL (used when NODE_ENV=production).
APP_URL_PROD=

# --- Email (Resend) -----------------------------------------------------
# API key from https://resend.com/api-keys. Leave blank in dev to fall back
# to logging emails to the server console instead of sending them.
RESEND_API_KEY=
# The verified sender address. Format: "Name <address@your-domain.com>".
EMAIL_FROM=
# Sender for admin-composed emails (the Email tab). Defaults to
# "StatiaWorks <hello@statiaworks.com>" when unset.
ADMIN_EMAIL_FROM=

# --- Auth ---------------------------------------------------------------
# Long random string — signs the JWTs. CHANGE THIS.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# --- Admin (env-based single admin) ------------------------------------
# ADMIN_PASSWORD_HASH is a bcrypt hash — generate with:  npm run hash -- "yourpassword"
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
# Optional pre-shared key gating the whole admin API (incl. login). When set,
# every /admin/* request must send a matching `X-Admin-Key` header or it 404s —
# hiding the admin surface from the public internet. The admin frontend sends it
# via VITE_ADMIN_KEY (admin/.env). Only keep this secret while the admin console
# is private (e.g. runs on your machine) — a public admin SPA cannot hide it, so
# this is defense-in-depth, never a replacement for the admin password. Leave
# blank to disable. Generate one with:  openssl rand -hex 32
ADMIN_API_KEY=

# --- Uploads / file storage ---------------------------------------------
# Uploaded files (résumés, cover letters, logos, payment proofs) are stored
# under the same '/uploads/<sub>/<file>' URL regardless of backend. The backend
# is chosen by NODE_ENV: development → local disk (UPLOAD_DIR), production →
# the Supabase Storage bucket below. Override with STORAGE_DRIVER=disk|supabase
# to exercise the Supabase path locally.
# STORAGE_DRIVER=
# Supabase Storage bucket name (created automatically on boot if missing).
# Deliberately 'uploads' — same word as the URL prefix — so no path mapping.
SUPABASE_STORAGE_BUCKET=uploads
# Directory (relative to server/) for the local disk driver (development).
UPLOAD_DIR=uploads
# Max upload size in megabytes.
MAX_UPLOAD_MB=8

# --- Attachment retention -----------------------------------------------
# Résumés/cover letters linked to an application become unavailable this many
# months after the job posting closes (ToS clause). The daily cleanup cron and
# the expiry date employers see both read this value.
ATTACHMENT_RETENTION_MONTHS=6

# --- Rate limiting ------------------------------------------------------
# Windows in minutes, maxes are requests per window per key. Defaults shown.
RL_GLOBAL_WINDOW_MIN=15
RL_GLOBAL_MAX=600
RL_AUTH_WINDOW_MIN=15
RL_AUTH_MAX=20
RL_APPLY_WINDOW_MIN=60
RL_APPLY_MAX=30
RL_UPLOAD_WINDOW_MIN=60
RL_UPLOAD_MAX=40
# Job postings are limited per-account AND per-IP (both use these values).
RL_POSTING_WINDOW_MIN=60
RL_POSTING_MAX=10

# --- Connection log -----------------------------------------------------
# How many recent requests the admin console's in-memory traffic monitor keeps.
# Not persisted — resets when the server restarts.
CONN_LOG_MAX=400
